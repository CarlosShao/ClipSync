# ClipSync 测试环境配置
# 只放密钥/密码等敏感信息，不放数据库名、端口等配置
# 数据库名、端口等由 config/test.js 配置文件控制

# 数据库密码（对应的 POSTGRES_PASSWORD 在 docker-compose.dev.yml 中设置）
DB_PASSWORD=dev_password_change_me

# Redis 密码（对应的 REQUIREPASS 在 docker-compose.dev.yml 中设置）
REDIS_PASSWORD=dev_redis_password

# JWT 签名密钥（生产环境必须更换，至少32字符）
JWT_SECRET=dev_jwt_secret_change_me_in_production

# 加密密钥（生产环境必须更换，至少32字符）
ENCRYPTION_KEY=dev_encryption_key_32_bytes_long_1234567890

# CSRF 密钥（生产环境必须更换，至少32字符）
CSRF_SECRET=dev_csrf_secret_change_me_in_production
