# ============================================
# ClipSync 环境变量配置示例
# 复制此文件为 .env 并填入真实值
# ============================================

# ============================================
# 服务器配置
# ============================================
NODE_ENV=development
PORT=3000
HOST=localhost
LOG_LEVEL=debug

# 请求超时（毫秒）
REQUEST_TIMEOUT=30000

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clipsync
DB_USER=postgres
DB_PASSWORD=your_secure_password

# ============================================
# Redis配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ============================================
# JWT配置
# ============================================
JWT_SECRET=your_super_secure_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ============================================
# CORS配置
# ============================================
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

# ============================================
# WebSocket配置
# ============================================
WS_HEARTBEAT_INTERVAL=30000
WS_HEARTBEAT_TIMEOUT=5000

# ============================================
# 加密配置
# ============================================
ENCRYPTION_ALGORITHM=aes-256-gcm

# ============================================
# 文件上传配置
# ============================================
MAX_FILE_SIZE=104857600
UPLOAD_DIR=./uploads

# ============================================
# 支付Webhook签名验证配置
# ============================================

# 微信支付
WECHAT_PAY_APIV3_KEY=your_wechat_pay_apiv3_key
WECHAT_PAY_MCH_ID=your_merchant_id

# 支付宝
ALIPAY_PUBLIC_KEY=your_alipay_public_key_in_pem_format

# Stripe
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# ============================================
# 邮件配置（可选）
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com

# ============================================
# 推送通知配置（可选）
# ============================================
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# ============================================
# 监控配置（可选）
# ============================================
PROMETHEUS_ENABLED=true
METRICS_PORT=9090
SENTRY_DSN=https://your_sentry_dsn@sentry.io/xxx
