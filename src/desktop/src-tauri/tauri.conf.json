{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "ClipSync",
  "version": "0.1.0",
  "identifier": "com.clipsync.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ClipSync",
        "width": 1180,
        "height": 760,
        "minWidth": 1100,
        "minHeight": 680,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true,
        "backgroundColor": "#000000",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dangerousDisablePluginAutostart": false,
      "endpoints": ["http://localhost:3001/api/app/update.json"],
      "pubkey": "placeholder_pubkey_replace_in_production"
    }
  }
}
