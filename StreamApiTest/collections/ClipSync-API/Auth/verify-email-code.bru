meta {
  name: "Verify Email Code",
  type: "http",
  seq: 2
}

post {
  url: "{{baseUrl}}/api/auth/verify-email-code",
  body: {
    "email": "test@example.com",
    "code": "888888"
  },
  header: {
    "Content-Type": "application/json"
  }
}

post-response {
  assert(resp.status === 200, "预期200");
  assert(resp.body.token !== undefined, "应包含token");
  assert(resp.body.user !== undefined, "应包含用户信息");
}

// 邮箱验证码登录/注册
