meta {
  name: "Forgot Password",
  type: "http",
  seq: 3
}

post {
  url: "{{baseUrl}}/api/auth/forgot-password",
  body: {
    "email": "test@example.com"
  },
  header: {
    "Content-Type": "application/json"
  }
}

post-response {
  assert(resp.status === 200, "预期200");
  console.log("MVP模式：密码重置码为 888888");
}

// 忘记密码（MVP：重置码固定为888888）
