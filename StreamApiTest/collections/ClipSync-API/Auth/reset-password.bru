meta {
  name: "Reset Password",
  type: "http",
  seq: 4
}

post {
  url: "{{baseUrl}}/api/auth/reset-password",
  body: {
    "email": "test@example.com",
    "code": "888888",
    "newPassword": "newpassword123"
  },
  header: {
    "Content-Type": "application/json"
  }
}

post-response {
  assert(resp.status === 200, "预期200");
  assert(resp.body.message !== undefined, "应包含成功消息");
}

// 重置密码
