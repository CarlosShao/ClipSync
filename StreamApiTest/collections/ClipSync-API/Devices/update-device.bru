meta {
    name: Update Device
    type: http
    seq: 4
}

put {
    url: {{baseUrl}}/api/devices/{{deviceId}}
    body: json
}

headers {
    Authorization: Bearer {{token}}
    x-csrf-token: {{csrfToken}}
    Content-Type: application/json
}

body:json {
    {
        "deviceName": "{{deviceName}}",
        "isActive": true
    }
}
