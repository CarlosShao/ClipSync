meta {
    name: Push Sync
    type: http
    seq: 2
}

post {
    url: {{baseUrl}}/api/sync/push
    body: json
}

headers {
    Authorization: Bearer {{token}}
    x-csrf-token: {{csrfToken}}
    Content-Type: application/json
}

body:json {
    {
        "deviceId": "{{deviceId}}",
        "items": [
            {
                "content": "{{content}}",
                "contentType": "text"
            }
        ]
    }
}
