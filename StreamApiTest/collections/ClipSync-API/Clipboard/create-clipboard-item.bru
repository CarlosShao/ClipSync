meta {
    name: Create Clipboard Item
    type: http
    seq: 2
}

post {
    url: {{baseUrl}}/api/clipboard
    body: json
}

headers {
    Authorization: Bearer {{token}}
    x-csrf-token: {{csrfToken}}
    Content-Type: application/json
}

body:json {
    {
        "content": "{{content}}",
        "contentType": "{{contentType}}",
        "sourceDeviceId": "{{deviceId}}"
    }
}
